---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PipelineBar from '../components/PipelineBar.astro';
import CtaBand from '../components/CtaBand.astro';
import MobileStickyCta from '../components/MobileStickyCta.astro';

const SITE_URL = 'https://aidriven.academy';

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: {
        '@type': 'Course',
        name: 'Formations initiales',
        description:
          "Deux parcours distincts (développement et produit) sur la méthode Spec-Driven Development, disponibles en modules unitaires, modules regroupés ou cohorte distancielle.",
        provider: { '@id': `${SITE_URL}/#organization` },
      },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: {
        '@type': 'Course',
        name: 'Kickstart Spec Driven',
        description:
          "Trois jours d'accompagnement embarqué auprès d'une équipe pour lancer une démarche Spec-Driven Development sur un projet réel.",
        provider: { '@id': `${SITE_URL}/#organization` },
      },
    },
    {
      '@type': 'ListItem',
      position: 3,
      item: {
        '@type': 'Course',
        name: 'Atelier Transfo IA',
        description:
          "Journée d'atelier collectif réunissant les équipes produit et développement autour d'une pratique commune de développement assisté par IA.",
        provider: { '@id': `${SITE_URL}/#organization` },
      },
    },
    {
      '@type': 'ListItem',
      position: 4,
      item: {
        '@type': 'Course',
        name: 'Lunch & Learn récurrent',
        description:
          "Sessions courtes et récurrentes pour entretenir la dynamique des équipes après le parcours de formation.",
        provider: { '@id': `${SITE_URL}/#organization` },
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Nos formations', item: `${SITE_URL}/offre` },
  ],
};
---
<Layout
  title="Formations IA : Kickstart, Ateliers, Lunch & Learn | AI Driven Academy"
  description="Quatre formats de formation en IA pour équipes tech & produit : formations initiales, Kickstart Spec Driven, ateliers collectifs, Lunch & Learn récurrent."
  path="/offre"
  structuredData={[courseSchema, breadcrumbSchema]}
>
  <div class="page-shell" style="background: rgb(255, 255, 255); color: var(--plum-900); min-width: 1240px;">

    <Header active="formations" />

    <main>

    <div class="bg-dots" style="color: rgb(255, 255, 255);">
      <div class="g-stack m-section-tight" style="display: grid; grid-template-columns: 1fr 440px; gap: 72px; align-items: center; padding: 88px 64px 72px;">
        <div>
          <div class="m-terminal" style="font-family: var(--font-mono); font-size: 15px; color: var(--orange-500); margin-bottom: 24px;">Nos formations<span style="display: inline-block; width: 10px; height: 19px; background: var(--orange-500); vertical-align: -3px; margin-left: 7px; animation: 1.1s step-end 0s infinite normal none running ada-blink;"></span></div>
          <h1 class="m-h1" style="font-family: var(--font-display); font-weight: 800; font-size: 56px; line-height: 1.06; letter-spacing: -0.025em; margin: 0px; color: rgb(255, 255, 255); text-wrap: balance;">Quatre formats indépendants. <span style="color: var(--orange-500);">Un parcours cohérent.</span></h1>
          <p class="m-body-lg" style="margin: 26px 0px 0px; font-size: 17px; line-height: 1.65; color: rgba(255, 255, 255, 0.72); text-wrap: pretty;">Chaque format répond seul à un besoin précis. Enchaînés dans l'ordre, ils forment un parcours pensé pour transformer les pratiques en profondeur. Peu d'organismes combinent formation, atelier collectif, accompagnement terrain et suivi dans la durée sous un même acteur.</p>
          <p class="m-body" style="margin: 18px 0px 0px; font-size: 15px; line-height: 1.6; color: rgba(255, 255, 255, 0.55);">Vous pouvez suivre le parcours complet, choisir un seul format, ou entrer directement à l'étape qui correspond à votre situation. Chaque format précise ci-dessous à qui il s'adresse, sa durée et sa modalité.</p>
        </div>
        <!-- Visuel hero : les 4 formats -->
        <div style="background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.45) 0px 24px 60px;">
          <div style="display: flex; align-items: center; gap: 8px; padding: 13px 18px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.03);">
            <span style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255, 255, 255, 0.18);"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: var(--orange-500);"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255, 255, 255, 0.18);"></span>
            <span style="font-family: var(--font-mono); font-size: 12.5px; color: rgba(255, 255, 255, 0.65); margin-left: 10px;">parcours.md</span>
          </div>
          <div style="display: flex; flex-direction: column; padding: 22px 24px 24px;">
            <a href="#formations" class="m-parcours-link" style="display: flex; align-items: center; gap: 16px; padding: 13px 16px; border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 10px; background: rgba(255, 255, 255, 0.03);">
              <span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-500); flex: none;">01</span>
              <span style="font-family: var(--font-display); font-weight: 700; font-size: 16.5px; color: rgb(255, 255, 255);">Formations initiales</span>
              <span style="margin-left: auto; font-family: var(--font-mono); font-size: 11.5px; color: rgba(255, 255, 255, 0.55);">modules</span>
            </a>
            <span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-500); margin: 3px 0px 3px 18px;">↓</span>
            <a href="#kickstart" class="m-parcours-link" style="display: flex; align-items: center; gap: 16px; padding: 13px 16px; border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 10px; background: rgba(255, 255, 255, 0.03);">
              <span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-500); flex: none;">02</span>
              <span style="font-family: var(--font-display); font-weight: 700; font-size: 16.5px; color: rgb(255, 255, 255);">Kickstart Spec Driven</span>
              <span style="margin-left: auto; font-family: var(--font-mono); font-size: 11.5px; color: rgba(255, 255, 255, 0.55);">projet</span>
            </a>
            <span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-500); margin: 3px 0px 3px 18px;">↓</span>
            <a href="#atelier" class="m-parcours-link" style="display: flex; align-items: center; gap: 16px; padding: 13px 16px; border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 10px; background: rgba(255, 255, 255, 0.03);">
              <span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-500); flex: none;">03</span>
              <span style="font-family: var(--font-display); font-weight: 700; font-size: 16.5px; color: rgb(255, 255, 255);">Atelier Transfo IA</span>
              <span style="margin-left: auto; font-family: var(--font-mono); font-size: 11.5px; color: rgba(255, 255, 255, 0.55);">collectif</span>
            </a>
            <span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-500); margin: 3px 0px 3px 18px;">↓</span>
            <a href="#bbl" class="m-parcours-link" style="display: flex; align-items: center; gap: 16px; padding: 13px 16px; border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 10px; background: rgba(255, 255, 255, 0.03);">
              <span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-500); flex: none;">04</span>
              <span style="font-family: var(--font-display); font-weight: 700; font-size: 16.5px; color: rgb(255, 255, 255);">Lunch & learn</span>
              <span style="margin-left: auto; font-family: var(--font-mono); font-size: 11.5px; color: rgba(255, 255, 255, 0.55);">récurrent</span>
            </a>
          </div>
        </div>
      </div>

      <PipelineBar items={[
        { label: '01 FORMATIONS', href: '#formations' },
        { label: '02 KICKSTART', href: '#kickstart' },
        { label: '03 ATELIER TRANSFO', href: '#atelier' },
        { label: '04 LUNCH & LEARN', href: '#bbl' },
        { label: 'VOS PRATIQUES', active: true },
      ]} />
    </div>

    <!-- Format 01 -->
    <div id="formations" class="m-section" style="background: rgb(255, 255, 255); padding: 96px 64px;">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">FORMAT 01</div>
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 480px; gap: 64px; align-items: end; margin-bottom: 44px;">
        <h2 class="m-h2" style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px; text-wrap: balance;">Formations initiales</h2>
        <p class="m-body-lg" style="margin: 0px; font-size: 16px; line-height: 1.6; color: var(--plum-600);">Deux parcours distincts, animés par des formateurs différents : un pour vos équipes de développement, un pour vos équipes produit.</p>
      </div>
      <p class="m-body-lg" style="margin: 0px 0px 32px; font-size: 16px; line-height: 1.65; color: var(--plum-600); max-width: 900px; text-wrap: pretty;">Chacun couvre la méthode sur son terrain, de l'analyse de marché et des retours utilisateurs jusqu'au code produit avec des agents, avant que les deux se rejoignent sur vos projets.</p>
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 40px;">
        <div class="card-lift m-card-pad" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 30px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div class="m-kicker" style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 14px;">TRACK DÉVELOPPEMENT</div>
          <p class="m-body" style="margin: 0px; font-size: 15.5px; line-height: 1.65; color: var(--plum-600);">Préparer le contexte, consommer une spec, produire du code avec des agents, le faire tenir en production. Vos développeurs repartent avec des pratiques communes, pas des astuces individuelles.</p>
        </div>
        <div class="card-lift m-card-pad" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 30px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div class="m-kicker" style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 14px;">TRACK PRODUIT</div>
          <p class="m-body" style="margin: 0px; font-size: 15.5px; line-height: 1.65; color: var(--plum-600);">Exploiter les retours utilisateurs et la veille concurrentielle avec des agents, cadrer un besoin, écrire des specs que les développeurs et leurs agents peuvent consommer sans les réinterpréter.</p>
        </div>
      </div>
      <h3 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 22px; margin: 0px 0px 20px;">Trois formats de délivrance, au choix</h3>
      <div style="border: 1px solid var(--plum-200); border-radius: 14px; overflow: hidden; box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
        <div class="m-table-head" style="display: grid; grid-template-columns: 1.2fr 1.6fr 1fr; gap: 24px; padding: 16px 32px; background: var(--plum-50); border-bottom: 1px solid var(--plum-200);">
          <span style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--plum-600);">FORMAT</span>
          <span style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--plum-600);">RYTHME</span>
          <span style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--plum-600);">MODALITÉ</span>
        </div>
        <div class="table-row-light m-table-row" style="display: grid; grid-template-columns: 1.2fr 1.6fr 1fr; gap: 24px; padding: 22px 32px; border-bottom: 1px solid var(--plum-200); align-items: baseline;">
          <span style="font-family: var(--font-display); font-weight: 700; font-size: 18px;">Modules unitaires</span>
          <span data-label="RYTHME" style="font-size: 15px; color: var(--plum-600);">½ journée par module</span>
          <span data-label="MODALITÉ" style="font-size: 15px; color: var(--plum-600);">Présentiel de préférence</span>
        </div>
        <div class="table-row-light m-table-row" style="display: grid; grid-template-columns: 1.2fr 1.6fr 1fr; gap: 24px; padding: 22px 32px; border-bottom: 1px solid var(--plum-200); align-items: baseline;">
          <span style="font-family: var(--font-display); font-weight: 700; font-size: 18px;">Modules regroupés</span>
          <span data-label="RYTHME" style="font-size: 15px; color: var(--plum-600);">1 ou 2 jours</span>
          <span data-label="MODALITÉ" style="font-size: 15px; color: var(--plum-600);">Présentiel</span>
        </div>
        <div class="table-row-light m-table-row" style="display: grid; grid-template-columns: 1.2fr 1.6fr 1fr; gap: 24px; padding: 22px 32px; align-items: baseline;">
          <span style="font-family: var(--font-display); font-weight: 700; font-size: 18px;">Cohorte</span>
          <span data-label="RYTHME" style="font-size: 15px; color: var(--plum-600);">Sessions de 1h30, quêtes à réaliser entre les sessions</span>
          <span data-label="MODALITÉ" style="font-size: 15px; color: var(--plum-600);">Distanciel</span>
        </div>
      </div>
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 48px; margin-top: 24px;">
        <p class="m-body" style="margin: 0px; font-size: 15px; line-height: 1.6; color: var(--plum-600); max-width: 820px;">Le format cohorte étale l'apprentissage dans le temps : chaque session se prolonge par une mise en pratique sur votre contexte réel, reprise en début de session suivante.</p>
      </div>
    </div>

    <!-- Format 02 -->
    <div id="kickstart" class="m-section" style="background: var(--plum-50); padding: 96px 64px; border-top: 1px solid var(--plum-200); border-bottom: 1px solid var(--plum-200);">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">FORMAT 02</div>
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 440px; gap: 64px; align-items: start;">
        <div>
          <h2 class="m-h2" style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px 0px 24px; text-wrap: balance;">Kickstart Spec Driven</h2>
          <p class="m-body-lg" style="margin: 0px 0px 20px; font-size: 16.5px; line-height: 1.65; color: var(--plum-600); max-width: 640px; text-wrap: pretty;">Trois jours d'accompagnement embarqué auprès d'une de vos équipes, pour lancer une démarche spec-driven sur un projet réel. La méthode s'applique sur votre code, vos specs, votre contexte, pas sur un cas d'école.</p>
          <div class="m-wrap" style="display: inline-flex; align-items: center; gap: 10px; border: 1px solid var(--plum-200); border-radius: 999px; padding: 10px 20px; background: rgb(255, 255, 255);">
            <span style="font-weight: 700; font-size: 13px;">3 jours</span>
            <span style="color: var(--plum-500);">·</span>
            <span style="font-size: 13.5px; color: var(--plum-600);">répartis selon le rythme du projet</span>
            <span style="color: var(--plum-500);">·</span>
            <span style="font-size: 13.5px; color: var(--plum-600);">peut se dérouler entièrement à distance</span>
          </div>
        </div>

        <div style="background: var(--plum-900); border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; overflow: hidden; box-shadow: rgba(63, 4, 52, 0.14) 0px 4px 24px; color: rgb(255, 255, 255);">
          <div style="display: flex; align-items: center; gap: 8px; padding: 13px 18px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.03);">
            <span style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255, 255, 255, 0.18);"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255, 255, 255, 0.18);"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: var(--orange-500);"></span>
            <span style="font-family: var(--font-mono); font-size: 12.5px; color: rgba(255, 255, 255, 0.65); margin-left: 10px;">readiness-check.md</span>
          </div>
          <div style="padding: 20px 24px; font-family: var(--font-mono); font-size: 13.5px; line-height: 2.1;">
            <div style="color: rgba(255, 255, 255, 0.4);"># Conditions de démarrage</div>
            <div><span style="color: var(--orange-500);">[✓]</span> <span style="color: rgba(255, 255, 255, 0.85);">équipe disponible sur la période</span></div>
            <div><span style="color: var(--orange-500);">[✓]</span> <span style="color: rgba(255, 255, 255, 0.85);">périmètre projet défini</span></div>
            <div><span style="color: var(--orange-500);">[✓]</span> <span style="color: rgba(255, 255, 255, 0.85);">prérequis techniques validés ensemble</span></div>
          </div>
        </div>
      </div>
      <div style="margin-top: 36px; border-left: 3px solid var(--orange-500); padding: 6px 0px 6px 24px; max-width: 860px;">
        <p style="margin: 0px; font-size: 15.5px; line-height: 1.65; color: var(--plum-600);">Nous ne démarrons pas un Kickstart sans ces trois conditions réunies. Un accompagnement lancé trop tôt fait perdre du temps à tout le monde. Nous préférons décaler un démarrage que de le rater.</p>
      </div>
    </div>

    <!-- Format 03 -->
    <div id="atelier" class="m-section" style="background: rgb(255, 255, 255); padding: 96px 64px;">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">FORMAT 03</div>
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 480px; gap: 64px; align-items: end; margin-bottom: 36px;">
        <h2 class="m-h2" style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px; text-wrap: balance;">Atelier Transfo IA</h2>
        <p class="m-body-lg" style="margin: 0px; font-size: 16px; line-height: 1.6; color: var(--plum-600);">C'est le moment où la méthode cesse d'être l'affaire de chaque équipe pour devenir celle de l'organisation.</p>
      </div>
      <p class="m-body-lg" style="margin: 0px 0px 28px; font-size: 16.5px; line-height: 1.65; color: var(--plum-600); max-width: 860px; text-wrap: pretty;">Une journée d'atelier collectif où vos équipes produit et développement travaillent ensemble, sur les mêmes cas, avec le même vocabulaire.</p>
      <div style="display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 28px;">
        <span style="display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--plum-200); border-radius: 999px; padding: 10px 20px; background: rgb(255, 255, 255); font-weight: 700; font-size: 13px;">1 journée</span>
        <span style="display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--plum-200); border-radius: 999px; padding: 10px 20px; background: rgb(255, 255, 255); font-weight: 700; font-size: 13px;">2 animateurs</span>
        <span style="display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--plum-200); border-radius: 999px; padding: 10px 20px; background: rgb(255, 255, 255); font-weight: 700; font-size: 13px;">jusqu'à 24 participants</span>
        <span class="m-body" style="display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--plum-200); border-radius: 999px; padding: 10px 20px; background: rgb(255, 255, 255); font-size: 13.5px; color: var(--plum-600);">Présentiel — groupes mixtes produit et développement, cas construits sur votre contexte</span>
      </div>
      <div style="border-left: 3px solid var(--orange-500); padding: 6px 0px 6px 24px; max-width: 860px;">
        <p class="m-body" style="margin: 0px; font-size: 15.5px; line-height: 1.65; color: var(--plum-600);">Après un Kickstart, l'atelier diffuse ce qu'une équipe pilote a éprouvé sur le terrain à l'ensemble du collectif.</p>
      </div>
    </div>

    <!-- Format 04 -->
    <div id="bbl" class="m-section" style="background: var(--plum-50); padding: 96px 64px; border-top: 1px solid var(--plum-200); border-bottom: 1px solid var(--plum-200);">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">FORMAT 04</div>
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 480px; gap: 64px; align-items: end; margin-bottom: 28px;">
        <h2 class="m-h2" style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px; text-wrap: balance;">Lunch & Learn récurrent</h2>
        <p class="m-body-lg" style="margin: 0px; font-size: 16px; line-height: 1.6; color: var(--plum-600);">Format court récurrent, sur site ou à distance, au rythme qui convient à vos équipes.</p>
      </div>
      <p class="m-body-lg" style="margin: 0px; font-size: 16.5px; line-height: 1.65; color: var(--plum-600); max-width: 860px; text-wrap: pretty;">Des sessions courtes et régulières pour entretenir la dynamique après le parcours : un sujet, un cas d'usage, à chaque fois. Les pratiques évoluent vite ; ce format maintient vos équipes à jour sans mobiliser des journées entières.</p>
    </div>

    <!-- Synthèse -->
    <div class="bg-dots m-section" style="padding: 96px 64px; color: rgb(255, 255, 255);">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-500); margin-bottom: 18px;">SYNTHÈSE</div>
