---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PipelineBar from '../components/PipelineBar.astro';
import CtaBand from '../components/CtaBand.astro';
import MobileStickyCta from '../components/MobileStickyCta.astro';
---
<Layout
  title="Formation Spec-Driven Development & IA | AI Driven Academy"
  description="Formations en développement assisté par IA pour équipes product & tech, méthode Spec-Driven Development conçue par un CPO et un CTO. Financement OPCO possible."
  path="/"
>
  <div class="page-shell" style="background: rgb(255, 255, 255); color: var(--plum-900); min-width: 1240px;">

    <Header active="accueil" />

    <main>
    <div class="bg-dots" style="color: rgb(255, 255, 255);">
      <div class="g-stack m-section-tight" style="display: grid; grid-template-columns: 1fr 440px; gap: 72px; align-items: center; padding: 96px 64px 76px;">
        <div>
          <div class="m-terminal" style="font-family: var(--font-mono); font-size: 15px; color: var(--orange-500); margin-bottom: 26px;">Vos équipes ont déjà les outils IA<span style="display: inline-block; width: 10px; height: 19px; background: var(--orange-500); vertical-align: -3px; margin-left: 7px; animation: 1.1s step-end 0s infinite normal none running ada-blink;"></span></div>
          <h1 class="m-h1 m-h1--home" style="font-family: var(--font-display); font-weight: 800; font-size: 56px; line-height: 1.06; letter-spacing: -0.025em; margin: 0px; color: rgb(255, 255, 255); text-wrap: balance;">Notre académie vous forme sur <span style="color: var(--orange-500);">la méthode AI Driven</span>, du Discovery à la Delivery.</h1>
          <p class="m-body-lg" style="margin: 28px 0px 0px; font-size: 17px; line-height: 1.6; color: rgba(255, 255, 255, 0.72); max-width: 700px; text-wrap: pretty;">Une méthode commune, de l'analyse de marché et des retours utilisateurs jusqu'au code produit avec des agents IA, conçue et portée par un CPO et un CTO.</p>
          <a href="/contact" class="btn-orange m-hide" style="display: inline-block; margin-top: 38px; background: var(--orange-500); color: rgb(255, 255, 255); font-weight: 700; font-size: 17px; padding: 18px 34px; border-radius: 12px;">Cadrer votre besoin</a>
        </div>
        <div style="background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.45) 0px 24px 60px;">
          <div style="display: flex; align-items: center; gap: 8px; padding: 13px 18px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.03);">
            <span style="width: 10px; height: 10px; border-radius: 50%; background: var(--orange-500);"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255, 255, 255, 0.18);"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255, 255, 255, 0.18);"></span>
            <span style="font-family: var(--font-mono); font-size: 12.5px; color: rgba(255, 255, 255, 0.65); margin-left: 10px;">feature-spec.md</span>
            <span style="font-family: var(--font-mono); font-size: 10.5px; color: var(--orange-500); margin-left: auto; letter-spacing: 0.12em;">ARTEFACT 02/04</span>
          </div>
          <div style="padding: 22px 24px; font-family: var(--font-mono); font-size: 13.5px; line-height: 2.05;">
            <div style="color: rgba(255, 255, 255, 0.4);"># Consommable par les humains et les agents</div>
            <div><span style="color: var(--orange-300);">contexte:</span> <span style="color: rgba(255, 255, 255, 0.85);">← prd.md §2</span></div>
            <div><span style="color: var(--orange-300);">critères_acceptation:</span> <span style="color: rgba(255, 255, 255, 0.85);">12 définis</span></div>
            <div><span style="color: var(--orange-300);">hors_périmètre:</span> <span style="color: rgba(255, 255, 255, 0.85);">explicite</span></div>
            <div style="display: flex; align-items: center; gap: 10px; margin: 4px 0px;"><span style="color: var(--orange-300);">relu_par:</span> <span style="display: inline-flex; align-items: center; gap: 6px; background: rgba(241, 107, 82, 0.14); border: 1px solid rgba(241, 107, 82, 0.45); border-radius: 6px; padding: 2px 10px; color: rgb(255, 255, 255); line-height: 1.7;">product <span style="color: var(--orange-500);">✓</span></span> <span style="display: inline-flex; align-items: center; gap: 6px; background: rgba(241, 107, 82, 0.14); border: 1px solid rgba(241, 107, 82, 0.45); border-radius: 6px; padding: 2px 10px; color: rgb(255, 255, 255); line-height: 1.7;">engineering <span style="color: var(--orange-500);">✓</span></span></div>
            <div><span style="color: var(--orange-300);">alimente:</span> <span style="color: rgba(255, 255, 255, 0.85);">→ plan.md → code</span></div>
          </div>
        </div>
      </div>

      <PipelineBar nextBg="var(--plum-900)" items={[
        { label: 'DISCOVERY' },
        { label: 'PRD' },
        { label: 'FEATURE SPEC', active: true },
        { label: 'PLAN' },
        { label: 'CODE' },
        { label: 'REVIEW' },
        { label: 'PROD' },
      ]} />
    </div>

    <!-- Bandeau confiance -->
    <div class="m-wrap-center m-logobar" style="display: flex; align-items: center; justify-content: space-between; padding: 36px 64px; background: var(--plum-900);">
      <img src="/assets/logos/anytime.png" alt="Anytime" class="m-logobar-item" style="height: 22px; width: auto; opacity: 0.62;" />
      <img src="/assets/logos/webedia.png" alt="Webedia" class="m-logobar-item" style="height: 20px; width: auto; opacity: 0.62;" />
      <img src="/assets/logos/leboncoin.svg" alt="leboncoin" class="m-logobar-item" style="height: 26px; width: auto; opacity: 0.62;" />
      <img src="/assets/logos/sofia.png" alt="Sofia" class="m-logobar-item" style="height: 30px; width: auto; opacity: 0.62;" />
      <img src="/assets/logos/edifice.png" alt="Edifice" class="m-logobar-item" style="height: 22px; width: auto; opacity: 0.62;" />
    </div>

    <!-- Le constat -->
    <div class="m-section" style="background: rgb(255, 255, 255); padding: 96px 64px;">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">LE CONSTAT</div>
      <h2 class="m-h2" style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px 0px 48px; max-width: 720px; text-wrap: balance;">Trois symptômes que vous avez peut-être déjà observés</h2>
      <div style="display: flex; flex-direction: column; gap: 14px;">
        <div class="card-lift card-lift--tint g-stack m-card-pad" style="display: grid; grid-template-columns: 170px 380px 1fr; gap: 32px; align-items: start; border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <span class="m-kicker" style="font-weight: 700; font-size: 12.5px; letter-spacing: 0.14em; color: var(--orange-700); padding-top: 5px;">SYMPTÔME 01</span>
          <h3 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.25; margin: 0px;">La qualité baisse, la vélocité ne monte pas</h3>
          <p class="m-body" style="margin: 0px; font-size: 15.5px; line-height: 1.6; color: var(--plum-600);">Les outils génèrent du code plus vite. Mais les reprises, les correctifs et les revues absorbent le gain. Au global, rien de mesurable ne s'améliore.</p>
        </div>
        <div class="card-lift card-lift--tint g-stack m-card-pad" style="display: grid; grid-template-columns: 170px 380px 1fr; gap: 32px; align-items: start; border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <span class="m-kicker" style="font-weight: 700; font-size: 12.5px; letter-spacing: 0.14em; color: var(--orange-700); padding-top: 5px;">SYMPTÔME 02</span>
          <h3 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.25; margin: 0px;">Product et engineering ne se comprennent plus</h3>
          <p class="m-body" style="margin: 0px; font-size: 15.5px; line-height: 1.6; color: var(--plum-600);">Les specs écrites côté produit ne sont consommables ni par les développeurs, ni par leurs agents. Chacun compense avec ses propres pratiques, et les pratiques divergent.</p>
        </div>
        <div class="card-lift card-lift--tint g-stack m-card-pad" style="display: grid; grid-template-columns: 170px 380px 1fr; gap: 32px; align-items: start; border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <span class="m-kicker" style="font-weight: 700; font-size: 12.5px; letter-spacing: 0.14em; color: var(--orange-700); padding-top: 5px;">SYMPTÔME 03</span>
          <h3 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.25; margin: 0px;">La consommation de tokens explose, pas la valeur livrée</h3>
          <p class="m-body" style="margin: 0px; font-size: 15.5px; line-height: 1.6; color: var(--plum-600);">Contexte mal préparé, specs floues, itérations en boucle : les agents tournent beaucoup, le produit n'avance pas au même rythme.</p>
        </div>
      </div>
    </div>

    <!-- La méthode -->
    <div class="m-section" style="background: var(--plum-50); padding: 96px 64px; border-top: 1px solid var(--plum-200); border-bottom: 1px solid var(--plum-200);">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">LA MÉTHODE</div>
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 480px; gap: 64px; align-items: end; margin-bottom: 44px;">
        <h2 class="m-h2" style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px; text-wrap: balance;">Une méthode qui couvre tout le cycle, pas seulement le code</h2>
        <p class="m-body-lg" style="margin: 0px; font-size: 16px; line-height: 1.6; color: var(--plum-600);">Le Spec-Driven Development structure le passage de la spec au code. Mais une spec ne vaut que par ce qui la précède, et un code ne vaut que par ce qui le suit. Notre méthode couvre les trois temps.</p>
      </div>
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <div class="card-slide g-stack m-card-pad" style="display: grid; grid-template-columns: 340px 1fr; gap: 32px; align-items: center; border: 1px solid var(--plum-200); border-radius: 14px; padding: 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.14) 0px 4px 24px;">
          <div style="font-family: var(--font-mono); font-size: 15px;"><span style="color: var(--orange-500);">▸</span> 01-avant-la-spec/</div>
          <p class="m-body" style="margin: 0px; font-size: 15px; line-height: 1.55; color: var(--plum-600);">Analyse de marché, veille concurrentielle, retours utilisateurs et avis clients exploités avec des agents. Le matériau qui rend une spec juste.</p>
        </div>
        <div class="m-card-pad" style="border: 2px solid var(--orange-500); border-radius: 14px; padding: 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.14) 0px 4px 24px; transition: transform 0.18s;">
          <div class="g-stack" style="display: grid; grid-template-columns: 340px 1fr; gap: 32px; align-items: center;">
            <div style="font-family: var(--font-mono); font-size: 15px;"><span style="color: var(--orange-500);">▸</span> 02-spec-driven-development/</div>
            <p class="m-body" style="margin: 0px; font-size: 15px; line-height: 1.55; color: var(--plum-600);">Chaque étape produit un artefact que l'étape suivante consomme, par les humains comme par les agents.</p>
          </div>
          <div class="m-wrap" style="display: flex; align-items: center; gap: 10px; margin: 20px 0px 0px 24px; font-family: var(--font-mono); font-size: 13px;">
            <span style="color: var(--plum-800); border: 1px solid var(--plum-500); padding: 7px 14px; border-radius: 8px;">prd.md</span>
            <span style="color: var(--orange-500);">→</span>
            <span style="color: var(--plum-800); border: 1px solid var(--plum-500); padding: 7px 14px; border-radius: 8px;">feature-spec.md</span>
            <span style="color: var(--orange-500);">→</span>
            <span style="color: var(--plum-800); border: 1px solid var(--plum-500); padding: 7px 14px; border-radius: 8px;">plan.md</span>
            <span style="color: var(--orange-500);">→</span>
            <span style="color: rgb(255, 255, 255); background: var(--orange-500); padding: 8px 14px; border-radius: 8px; font-weight: 700;">code/</span>
          </div>
        </div>
        <div class="card-slide g-stack m-card-pad" style="display: grid; grid-template-columns: 340px 1fr; gap: 32px; align-items: center; border: 1px solid var(--plum-200); border-radius: 14px; padding: 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.14) 0px 4px 24px;">
          <div style="font-family: var(--font-mono); font-size: 15px;"><span style="color: var(--orange-500);">▸</span> 03-après-le-code/</div>
          <p class="m-body" style="margin: 0px; font-size: 15px; line-height: 1.55; color: var(--plum-600);">Review, tests, évaluation, monitoring, observabilité. Ce qui garantit que le code produit avec des agents tient en production.</p>
        </div>
      </div>
    </div>

    <!-- Nos formations -->
    <div id="offre" class="m-section" style="background: rgb(255, 255, 255); padding: 96px 64px;">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">Nos formations</div>
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 480px; gap: 64px; align-items: end; margin-bottom: 44px;">
        <h2 class="m-h2" style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px; text-wrap: balance;">Quatre formats qui s'enchaînent. <span style="color: var(--orange-500);">Ou pas.</span></h2>
        <p class="m-body-lg" style="margin: 0px; font-size: 16px; line-height: 1.6; color: var(--plum-600);">Chaque format répond seul à un besoin précis. Enchaînés, ils forment un parcours.</p>
      </div>
      <div class="g-stack" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;">
        <div class="card-lift card-lift--tint m-card-pad" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div class="m-kicker" style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 18px;">FORMAT 01</div>
          <h3 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.2; margin: 0px 0px 10px;">Formations initiales</h3>
          <p class="m-body" style="margin: 0px; font-size: 14.5px; line-height: 1.55; color: var(--plum-600);">Modules de formation product &amp; tech, adaptés au niveau de chaque équipe.</p>
        </div>
        <div class="card-lift card-lift--tint m-card-pad" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div class="m-kicker" style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 18px;">FORMAT 02</div>
          <h3 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.2; margin: 0px 0px 10px;">Kickstart Spec Driven</h3>
          <p class="m-body" style="margin: 0px; font-size: 14.5px; line-height: 1.55; color: var(--plum-600);">Accompagnement terrain auprès d'une équipe pour lancer la démarche sur un projet réel.</p>
        </div>
        <div class="card-lift card-lift--tint m-card-pad" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div class="m-kicker" style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 18px;">FORMAT 03</div>
          <h3 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.2; margin: 0px 0px 10px;">Atelier Transfo IA</h3>
          <p class="m-body" style="margin: 0px; font-size: 14.5px; line-height: 1.55; color: var(--plum-600);">Atelier collectif pour aligner les équipes sur une pratique commune.</p>
        </div>
        <div class="card-lift card-lift--tint m-card-pad" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div class="m-kicker" style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 18px;">FORMAT 04</div>
          <h3 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.2; margin: 0px 0px 10px;">Lunch & Learn récurrent</h3>
          <p class="m-body" style="margin: 0px; font-size: 14.5px; line-height: 1.55; color: var(--plum-600);">Un suivi dans la durée : un sujet, un cas d'usage, un invité externe.</p>
        </div>
      </div>
      <div class="g-stack" style="display: flex; align-items: center; justify-content: space-between; gap: 48px; margin-top: 36px; padding-top: 26px; border-top: 1px solid var(--plum-200);">
        <p class="m-body" style="margin: 0px; font-size: 15px; line-height: 1.55; color: var(--plum-600); max-width: 820px;">Peu d'organismes combinent formation, atelier collectif, accompagnement terrain et suivi dans la durée sous un même acteur.</p>
        <a href="/offre" style="font-weight: 700; font-size: 15.5px; color: var(--plum-900); border-bottom: 2px solid var(--orange-500); padding-bottom: 2px; white-space: nowrap;">Voir le détail des formats →</a>
      </div>
    </div>

    <!-- Études de cas -->
    <div id="cas" class="bg-dots m-section" style="padding: 96px 64px; color: rgb(255, 255, 255);">
      <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-500); margin-bottom: 18px;">ÉTUDES DE CAS</div>
      <h2 class="m-h2" style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px 0px 44px; color: rgb(255, 255, 255); text-wrap: balance;">Ce que ça change sur le terrain</h2>
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;">
        <div class="m-card-pad" style="background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; padding: 40px 44px 34px; display: flex; flex-direction: column;">
          <div style="font-family: var(--font-display); font-weight: 800; font-size: 64px; line-height: 0.6; color: var(--orange-500); margin-bottom: 22px;">&ldquo;</div>
          <p class="m-h3" style="margin: 0px 0px 20px; font-family: var(--font-display); font-weight: 700; font-size: 23px; line-height: 1.35; letter-spacing: -0.01em; color: rgb(255, 255, 255); max-width: 620px;">On avait besoin d'un renfort externe pour accélérer. Ce programme nous a servi de déclencheur pour créer une vraie dynamique de groupe.</p>
          <p class="m-body" style="margin: 0px 0px 30px; font-size: 15.5px; line-height: 1.6; color: rgba(255, 255, 255, 0.72); max-width: 620px;"><strong style="color: rgb(255, 255, 255);">Ce qui a changé —</strong> « On voit clairement que l'énergie concentrée a fait que tout le monde s'y mette. Cette dynamique a fonctionné. Il y a un avant et un après marqué. »</p>
          <div style="margin-top: auto; display: flex; align-items: center; gap: 12px;">
            <img src="/assets/photo-nicolas-lauquin.jpg" alt="Nicolas Lauquin" loading="lazy" decoding="async" width="40" height="40" style="width: 40px; height: 40px; border-radius: 10px; object-fit: cover; display: block;" />
            <div>
              <div style="font-weight: 700; font-size: 15px; color: rgb(255, 255, 255);">Nicolas Lauquin</div>
              <div style="font-weight: 600; font-size: 12.5px; letter-spacing: 0.1em; color: rgba(255, 255, 255, 0.72);">Directeur Technique IA &amp; Mobile — SOFIA</div>
            </div>
          </div>
        </div>
        <div class="m-card-pad" style="background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; padding: 40px 44px 34px; display: flex; flex-direction: column;">
          <div style="font-family: var(--font-display); font-weight: 800; font-size: 64px; line-height: 0.6; color: var(--orange-500); margin-bottom: 22px;">&ldquo;</div>
          <p class="m-h3" style="margin: 0px 0px 30px; font-family: var(--font-display); font-weight: 700; font-size: 23px; line-height: 1.35; letter-spacing: -0.01em; color: rgb(255, 255, 255); max-width: 620px;">Une formation très percutante : le minimum nécessaire de théorie, une bonne dose de pratique sur un cas conçu spécifiquement pour nous, et des retours d'expérience du formateur directement applicables à nos problématiques. Résultat : l'équipe PM et Design est aujourd'hui outillée et motivée pour livrer des features assistées par IA.</p>
          <div style="margin-top: auto; display: flex; align-items: center; gap: 12px;">
            <img src="/assets/photo-frederic-oru.jpg" alt="Frédéric Oru" loading="lazy" decoding="async" width="40" height="40" style="width: 40px; height: 40px; border-radius: 10px; object-fit: cover; display: block;" />
            <div>
              <div style="font-weight: 700; font-size: 15px; color: rgb(255, 255, 255);">Frédéric Oru</div>
              <div style="font-weight: 600; font-size: 12.5px; letter-spacing: 0.1em; color: rgba(255, 255, 255, 0.72);">HEAD OF AI &amp; DATA — EDIFICE</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Équipe -->
    <div id="equipe" class="m-section" style="background: rgb(255, 255, 255); padding: 96px 64px;">
