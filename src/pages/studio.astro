---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBand from '../components/CtaBand.astro';

const MAILTO = "mailto:contact@aidrivenacademy.com?subject=Partenariat%20AI%20Academy%20Studio";
---
<Layout
  title="AI Academy Studio — marque blanche | AI Driven Academy"
  description="Vendez une offre de formation IA sous votre marque : conception, delivery et mise à jour par AI Driven Academy. Partenariat ESN et cabinets de conseil."
  path="/studio"
  noindex={true}
>
  <div style="background: rgb(255, 255, 255); color: var(--plum-900); min-width: 1240px;">

    <Header active="studio" />

    <main>

    <div class="bg-dots" style="color: rgb(255, 255, 255);">
      <div style="display: grid; grid-template-columns: 1fr 440px; gap: 72px; align-items: center; padding: 96px 64px;">
        <div>
          <div style="font-family: var(--font-mono); font-size: 15px; color: var(--orange-500); margin-bottom: 26px;">$ vos clients vous demandent de la formation IA<span style="display: inline-block; width: 10px; height: 19px; background: var(--orange-500); vertical-align: -3px; margin-left: 7px; animation: 1.1s step-end 0s infinite normal none running ada-blink;"></span></div>
          <h1 style="font-family: var(--font-display); font-weight: 800; font-size: 56px; line-height: 1.08; letter-spacing: -0.025em; margin: 0px; color: rgb(255, 255, 255); text-wrap: balance;">Vendez une offre de formation IA <span style="color: var(--orange-500);">sous votre marque</span>, propulsée par notre méthode.</h1>
          <p style="margin: 24px 0px 0px; font-size: 19px; line-height: 1.55; color: rgba(255, 255, 255, 0.85); max-width: 700px;">Nous la concevons, la délivrons et la maintenons à jour.</p>
          <p style="margin: 18px 0px 0px; font-size: 16px; line-height: 1.6; color: rgba(255, 255, 255, 0.72); max-width: 700px; text-wrap: pretty;">Vous n'avez ni le temps de construire un curriculum qui se périme en trois mois, ni l'envie de le maintenir. C'est notre métier.</p>
          <a href={MAILTO} class="btn-orange" style="display: inline-block; margin-top: 38px; background: var(--orange-500); color: rgb(255, 255, 255); font-weight: 700; font-size: 17px; padding: 18px 34px; border-radius: 12px;">Échanger sur un partenariat</a>
        </div>

        <div style="background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; overflow: hidden; box-shadow: rgba(0, 0, 0, 0.45) 0px 24px 60px;">
          <div style="display: flex; align-items: center; gap: 8px; padding: 13px 18px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.03);">
            <span style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255, 255, 255, 0.18);"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255, 255, 255, 0.18);"></span>
            <span style="width: 10px; height: 10px; border-radius: 50%; background: var(--orange-500);"></span>
            <span style="font-family: var(--font-mono); font-size: 12.5px; color: rgba(255, 255, 255, 0.65); margin-left: 10px;">votre-offre-intra.md</span>
          </div>
          <div style="padding: 26px 24px 24px;">
            <div style="border: 1.5px dashed rgba(255, 255, 255, 0.35); border-radius: 10px; padding: 18px 20px; text-align: center;">
              <div style="font-family: var(--font-display); font-weight: 800; font-size: 22px; letter-spacing: 0.06em; color: rgba(255, 255, 255, 0.85);">VOTRE MARQUE</div>
              <div style="margin-top: 6px; font-size: 13px; color: rgba(255, 255, 255, 0.55);">Formation IA — équipes product &amp; tech</div>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0px; margin: 18px 0px 0px; font-family: var(--font-mono); font-size: 13px; line-height: 2;">
              <div><span style="color: var(--orange-300);">vendu_par:</span> <span style="color: rgba(255, 255, 255, 0.85);">vous</span></div>
              <div><span style="color: var(--orange-300);">délivré_par:</span> <span style="color: rgba(255, 255, 255, 0.85);">nous</span></div>
              <div><span style="color: var(--orange-300);">curriculum:</span> <span style="color: rgba(255, 255, 255, 0.85);">maintenu à jour en continu</span></div>
            </div>
            <div style="display: inline-flex; align-items: center; gap: 9px; margin-top: 18px; background: rgba(241, 107, 82, 0.14); border: 1px solid rgba(241, 107, 82, 0.45); border-radius: 999px; padding: 8px 16px;">
              <img src="/assets/icon-orange.png" alt="" width="18" height="18" style="width: 18px; height: 18px; border-radius: 5px; display: block;" />
              <span style="font-weight: 700; font-size: 12.5px; letter-spacing: 0.06em; color: rgb(255, 255, 255);">Powered by AI Driven Academy</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Pour qui -->
    <div style="background: rgb(255, 255, 255); padding: 96px 64px;">
      <div style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">POUR QUI</div>
      <h2 style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px 0px 44px; max-width: 720px; text-wrap: balance;">Ce modèle s'adresse à quatre profils</h2>
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;">
        <div class="card-lift card-lift--tint" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.2; margin: 0px 0px 10px;">ESN</h3>
          <p style="margin: 0px; font-size: 14.5px; line-height: 1.6; color: var(--plum-600);">Vos clients vous sollicitent sur l'IA. Vous montez une offre de formation crédible sans immobiliser vos consultants.</p>
        </div>
        <div class="card-lift card-lift--tint" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.2; margin: 0px 0px 10px;">Cabinets de conseil</h3>
          <p style="margin: 0px; font-size: 14.5px; line-height: 1.6; color: var(--plum-600);">Vous prolongez vos missions de transformation par un volet montée en compétences, sous votre marque.</p>
        </div>
        <div class="card-lift card-lift--tint" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.2; margin: 0px 0px 10px;">Communautés dev</h3>
          <p style="margin: 0px; font-size: 14.5px; line-height: 1.6; color: var(--plum-600);">Vous monétisez votre audience avec une offre intra crédible techniquement, animée par des praticiens.</p>
        </div>
        <div class="card-lift card-lift--tint" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 26px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 21px; line-height: 1.2; margin: 0px 0px 10px;">Communautés product</h3>
          <p style="margin: 0px; font-size: 14.5px; line-height: 1.6; color: var(--plum-600);">Vous offrez à vos membres une formation qui couvre le cycle complet, du Discovery à la Delivery, pas seulement le code.</p>
        </div>
      </div>
    </div>

    <!-- Ce que vous vendez -->
    <div style="background: var(--plum-50); padding: 96px 64px; border-top: 1px solid var(--plum-200); border-bottom: 1px solid var(--plum-200);">
      <div style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">CE QUE VOUS VENDEZ</div>
      <div style="display: grid; grid-template-columns: 1fr 480px; gap: 64px; align-items: end; margin-bottom: 44px;">
        <h2 style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px; text-wrap: balance;">L'offre AI Driven Academy, sous votre marque</h2>
        <p style="margin: 0px; font-size: 16px; line-height: 1.6; color: var(--plum-600);">Quatre formats combinables, de la formation initiale à l'accompagnement terrain, couvrant le cycle produit complet, de l'analyse de marché au code produit avec des agents.</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;">
        <div class="card-lift" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 24px 26px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 12px;">FORMAT 01</div>
          <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 20px; line-height: 1.2; margin: 0px;">Formations initiales</h3>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px;">
            <span style="font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--plum-600); border: 1px solid var(--plum-200); border-radius: 999px; padding: 4px 12px; background: var(--plum-50);">Intra-entreprise</span>
            <span style="font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--plum-600); border: 1px solid var(--plum-200); border-radius: 999px; padding: 4px 12px; background: var(--plum-50);">Inter-entreprises</span>
          </div>
        </div>
        <div class="card-lift" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 24px 26px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 12px;">FORMAT 02</div>
          <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 20px; line-height: 1.2; margin: 0px;">Kickstart Spec Driven</h3>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px;">
            <span style="font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--plum-600); border: 1px solid var(--plum-200); border-radius: 999px; padding: 4px 12px; background: var(--plum-50);">Intra-entreprise</span>
          </div>
        </div>
        <div class="card-lift" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 24px 26px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 12px;">FORMAT 03</div>
          <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 20px; line-height: 1.2; margin: 0px;">Atelier Transfo IA</h3>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px;">
            <span style="font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--plum-600); border: 1px solid var(--plum-200); border-radius: 999px; padding: 4px 12px; background: var(--plum-50);">Intra-entreprise</span>
          </div>
        </div>
        <div class="card-lift" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 24px 26px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 12px;">FORMAT 04</div>
          <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 20px; line-height: 1.2; margin: 0px;">BBL récurrent</h3>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px;">
            <span style="font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--plum-600); border: 1px solid var(--plum-200); border-radius: 999px; padding: 4px 12px; background: var(--plum-50);">Intra-entreprise</span>
            <span style="font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--plum-600); border: 1px solid var(--plum-200); border-radius: 999px; padding: 4px 12px; background: var(--plum-50);">Inter-entreprises</span>
          </div>
        </div>
      </div>
      <div style="margin-top: 24px; font-size: 14.5px; line-height: 1.6; color: var(--plum-600);">Formations initiales et BBL sont également disponibles en inter-entreprises, pour regrouper des participants de plusieurs clients.</div>
      <div style="margin-top: 14px; font-size: 15px; color: var(--plum-600);">Le détail des formats est présenté sur <a href="/offre" style="font-weight: 700; color: var(--plum-900); border-bottom: 2px solid var(--orange-500); padding-bottom: 1px;">l'offre AI Driven Academy</a>.</div>
    </div>

    <!-- Notre valeur unique -->
    <div style="background: rgb(255, 255, 255); padding: 96px 64px;">
      <div style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">NOTRE VALEUR UNIQUE</div>
      <div style="display: grid; grid-template-columns: 1fr 480px; gap: 64px; align-items: end; margin-bottom: 44px;">
        <h2 style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px; text-wrap: balance;">Le curriculum vivant<span style="color: var(--orange-500);">.</span> Un contenu qui ne se périme jamais.</h2>
        <p style="margin: 0px; font-size: 16px; line-height: 1.6; color: var(--plum-600);">Une méthodologie de veille et de mise à jour continue des contenus. Vous vendez une offre à jour, sans effort de production de votre côté.</p>
      </div>
      <div class="card-lift" style="border: 2px solid var(--orange-500); border-radius: 14px; padding: 32px 36px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.14) 0px 4px 24px;">
        <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; font-family: var(--font-mono); font-size: 13.5px;">
          <span style="color: var(--plum-800); border: 1px solid var(--plum-500); padding: 8px 16px; border-radius: 8px;">session délivrée</span>
          <span style="color: var(--orange-500); font-weight: 700;">→</span>
          <span style="color: var(--plum-800); border: 1px solid var(--plum-500); padding: 8px 16px; border-radius: 8px;">retours terrain</span>
          <span style="color: var(--orange-500); font-weight: 700;">+</span>
          <span style="color: var(--plum-800); border: 1px solid var(--plum-500); padding: 8px 16px; border-radius: 8px;">veille écosystème</span>
          <span style="color: var(--orange-500); font-weight: 700;">→</span>
          <span style="color: rgb(255, 255, 255); background: var(--orange-500); padding: 9px 16px; border-radius: 8px; font-weight: 700;">curriculum/</span>
          <span style="color: var(--orange-500); font-weight: 700;">→</span>
          <span style="color: var(--plum-800); border: 1px solid var(--plum-500); padding: 8px 16px; border-radius: 8px;">votre prochaine vente</span>
        </div>
        <p style="margin: 22px 0px 0px; font-size: 16px; line-height: 1.65; color: var(--plum-600); max-width: 860px;">Chaque session délivrée et chaque évolution de l'écosystème alimente le curriculum. C'est ce qui rend l'offre défendable face à un curriculum construit une fois, qui se périme en trois mois.</p>
      </div>
    </div>

    <!-- La répartition des rôles -->
    <div class="bg-dots" style="padding: 96px 64px; color: rgb(255, 255, 255);">
      <div style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-500); margin-bottom: 18px;">LA RÉPARTITION DES RÔLES</div>
      <h2 style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px 0px 44px; color: rgb(255, 255, 255); text-wrap: balance;">Vous vendez. Nous délivrons.</h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px;">
        <div class="card-slide" style="border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; padding: 32px 34px; background: rgba(255, 255, 255, 0.03);">
          <div style="font-family: var(--font-mono); font-size: 15px; color: rgb(255, 255, 255); margin-bottom: 14px;"><span style="color: var(--orange-500);">▸</span> vous/</div>
          <p style="margin: 0px; font-size: 16px; line-height: 1.65; color: rgba(255, 255, 255, 0.72);">La relation commerciale, votre marque en première ligne, le prix client final.</p>
        </div>
        <div class="card-slide" style="border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; padding: 32px 34px; background: rgba(255, 255, 255, 0.03);">
          <div style="font-family: var(--font-mono); font-size: 15px; color: rgb(255, 255, 255); margin-bottom: 14px;"><span style="color: var(--orange-500);">▸</span> nous/</div>
          <p style="margin: 0px; font-size: 16px; line-height: 1.65; color: rgba(255, 255, 255, 0.72);">La conception pédagogique, la mise à jour des contenus, l'animation des sessions, la gestion administrative des formations.</p>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;">
        <div style="border: 2px solid var(--orange-500); border-radius: 14px; padding: 32px 34px; background: rgba(241, 107, 82, 0.07); transition: transform 0.18s;">
          <div style="display: inline-flex; align-items: center; gap: 9px; background: rgba(241, 107, 82, 0.14); border: 1px solid rgba(241, 107, 82, 0.45); border-radius: 999px; padding: 8px 16px; margin-bottom: 18px;">
            <img src="/assets/icon-orange.png" alt="" width="18" height="18" style="width: 18px; height: 18px; border-radius: 5px; display: block;" />
            <span style="font-weight: 700; font-size: 12.5px; letter-spacing: 0.06em; color: rgb(255, 255, 255);">Powered by AI Driven Academy</span>
          </div>
          <p style="margin: 0px; font-size: 16px; line-height: 1.65; color: rgba(255, 255, 255, 0.72);">Vos clients achètent votre marque. Le badge leur garantit que la méthode derrière est conçue et maintenue par un CPO et un CTO en exercice. Vous vendez sous votre nom, avec une caution méthodologique visible.</p>
        </div>
        <div class="card-slide" style="border: 1px solid rgba(255, 255, 255, 0.13); border-radius: 14px; padding: 32px 34px; background: rgba(255, 255, 255, 0.03);">
          <div style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-500); margin-bottom: 18px;">LA PREUVE</div>
          <p style="margin: 0px; font-size: 16px; line-height: 1.65; color: rgba(255, 255, 255, 0.72);">Nous savons faire fonctionner un centre de formation : recrutement, formation et animation de formateurs. Nous l'avons déjà construit avec <strong style="color: rgb(255, 255, 255);">The Green Compagnon</strong>, organisme qui fédère plus de 250 membres et 40 formateurs.</p>
        </div>
      </div>
    </div>

    <!-- Le modèle -->
    <div style="background: rgb(255, 255, 255); padding: 96px 64px;">
      <div style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 18px;">LE MODÈLE</div>
      <div style="display: grid; grid-template-columns: 1fr 480px; gap: 64px; align-items: start;">
        <div>
          <h2 style="font-family: var(--font-display); font-weight: 800; font-size: 40px; line-height: 1.1; letter-spacing: -0.02em; margin: 0px 0px 24px; text-wrap: balance;">Un partenariat de distribution, <span style="color: var(--orange-500);">pas une marketplace</span></h2>
          <p style="margin: 0px; font-size: 16.5px; line-height: 1.65; color: var(--plum-600); max-width: 640px; text-wrap: pretty;">Vous gardez une part du prix de vente en tant que distributeur. Nous assurons la production et la delivery. Les modalités de marque, de tarification et d'engagement se définissent ensemble, selon votre contexte et votre volume.</p>
        </div>
        <div class="card-lift" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 32px; background: var(--plum-50); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
          <div style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 14px;">FINANCEMENT</div>
          <p style="margin: 0px; font-size: 15.5px; line-height: 1.6; color: var(--plum-600);">Les formations sont portées par un organisme certifié Qualiopi : vos clients peuvent mobiliser un financement OPCO.</p>
        </div>
      </div>
    </div>

    <CtaBand
      heading="Parlons-en directement"
      body="Pas de formulaire. Écrivez-nous ou réservez un créneau : nous validons ensemble en trente minutes si le modèle correspond à votre contexte."
      ctaLabel="Échanger sur un partenariat"
      ctaHref={MAILTO}
    />
    </main>

    <Footer variant="minimal" />
  </div>
</Layout>
