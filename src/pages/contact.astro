---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE_URL = 'https://aidriven.academy';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Cadrer votre besoin', item: `${SITE_URL}/contact` },
  ],
};

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Cadrer votre besoin — AI Driven Academy',
  url: `${SITE_URL}/contact`,
  about: { '@id': `${SITE_URL}/#organization` },
};
---
<Layout
  title="Cadrer votre besoin — Contact | AI Driven Academy"
  description="Décrivez-nous vos équipes et votre contexte. Nous revenons vers vous avec le format de formation IA adapté, du module d'une demi-journée au parcours complet."
  path="/contact"
  structuredData={[breadcrumbSchema, contactPageSchema]}
>
  <div class="page-shell" style="background: rgb(255, 255, 255); color: var(--plum-900); min-width: 1240px;">

    <Header active="contact" />

    <main>
    <div class="bg-dots m-section-tight" style="color: rgb(255, 255, 255); padding: 72px 64px 64px;">
      <div class="m-terminal" style="font-family: var(--font-mono); font-size: 15px; color: var(--orange-500); margin-bottom: 24px;">Décrivez-nous votre contexte<span style="display: inline-block; width: 10px; height: 19px; background: var(--orange-500); vertical-align: -3px; margin-left: 7px; animation: 1.1s step-end 0s infinite normal none running ada-blink;"></span></div>
      <h1 class="m-h1" style="font-family: var(--font-display); font-weight: 800; font-size: 56px; line-height: 1.06; letter-spacing: -0.025em; margin: 0px; color: rgb(255, 255, 255); max-width: 900px; text-wrap: balance;">Cadrer votre besoin</h1>
      <p class="m-body-lg" style="margin: 22px 0px 0px; font-size: 17px; line-height: 1.6; color: rgba(255, 255, 255, 0.72); max-width: 700px; text-wrap: pretty;">Décrivez-nous vos équipes, vos projets en cours et là où ça coince. Nous revenons vers vous avec le format ou la combinaison adaptée — pas de séquence commerciale, une lecture attentive et une réponse argumentée.</p>
    </div>

    <div class="m-section" style="background: rgb(255, 255, 255); padding: 80px 64px 96px;">
      <div class="g-stack" style="display: grid; grid-template-columns: 1fr 420px; gap: 64px; align-items: start;">

        <div>
          <div class="m-kicker" style="font-weight: 700; font-size: 13px; letter-spacing: 0.18em; color: var(--orange-700); margin-bottom: 28px;">ÉCRIVEZ-NOUS</div>

          <form id="contact-form" novalidate style="display: flex; flex-direction: column; gap: 22px; max-width: 640px;">
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <label for="f-email" style="font-weight: 700; font-size: 14.5px;">Votre email professionnel</label>
              <input id="f-email" name="email" type="email" required placeholder="prenom@entreprise.com" style="font-family: Figtree, system-ui, sans-serif; font-size: 15.5px; padding: 14px 16px; border: 1px solid var(--plum-200); border-radius: 10px; background: rgb(255, 255, 255); color: var(--plum-900); outline: none;" />
              <span class="field-error" data-error-for="f-email" style="display: none; font-size: 13px; color: #C0392B;"></span>
            </div>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <label for="f-tel" style="font-weight: 700; font-size: 14.5px;">Votre téléphone <span style="font-weight: 500; color: var(--plum-500);">— optionnel</span></label>
              <input id="f-tel" name="tel" type="tel" placeholder="06 12 34 56 78" style="font-family: Figtree, system-ui, sans-serif; font-size: 15.5px; padding: 14px 16px; border: 1px solid var(--plum-200); border-radius: 10px; background: rgb(255, 255, 255); color: var(--plum-900); outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <label for="f-contexte" style="font-weight: 700; font-size: 14.5px;">Votre contexte <span style="font-weight: 500; color: var(--plum-500);">— vos équipes, vos projets en cours, ce qui coince</span></label>
              <textarea id="f-contexte" name="contexte" required rows="5" placeholder="Deux ou trois phrases suffisent." style="font-family: Figtree, system-ui, sans-serif; font-size: 15.5px; line-height: 1.6; padding: 14px 16px; border: 1px solid var(--plum-200); border-radius: 10px; background: rgb(255, 255, 255); color: var(--plum-900); outline: none; resize: vertical;"></textarea>
              <span class="field-error" data-error-for="f-contexte" style="display: none; font-size: 13px; color: #C0392B;"></span>
            </div>
            <div class="m-wrap" style="display: flex; align-items: center; gap: 24px; margin-top: 6px;">
              <button type="submit" id="contact-submit" class="btn-orange m-cta-block" style="display: inline-block; background: var(--orange-500); color: rgb(255, 255, 255); font-weight: 700; font-size: 17px; padding: 18px 36px; border-radius: 12px; border: none; cursor: pointer;">Envoyer</button>
              <span style="font-family: var(--font-mono); font-size: 12.5px; color: var(--plum-600);">Financement OPCO possible.</span>
            </div>
            <p id="contact-success" role="status" style="display: none; margin: 0px; font-size: 15px; line-height: 1.6; color: #2D7D46; font-weight: 600;">Merci, votre message a bien été envoyé. Nous revenons vers vous rapidement.</p>
            <p id="contact-failure" role="alert" style="display: none; margin: 0px; font-size: 15px; line-height: 1.6; color: #C0392B; font-weight: 600;">Une erreur est survenue lors de l'envoi. Réessayez ou écrivez-nous directement à nicolas@thegreencompagnon.com.</p>
          </form>
        </div>

        <div style="display: flex; flex-direction: column; gap: 14px;">
          <div class="card-lift m-card-pad" style="border: 2px solid var(--orange-500); border-radius: 14px; padding: 30px 32px; background: rgb(255, 255, 255); box-shadow: rgba(63, 4, 52, 0.14) 0px 4px 24px;">
            <div class="m-kicker" style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 14px;">OU PLUS DIRECT</div>
            <h2 class="m-h3" style="font-family: var(--font-display); font-weight: 700; font-size: 22px; line-height: 1.2; margin: 0px 0px 10px;">Réservez directement un créneau</h2>
            <p class="m-body" style="margin: 0px 0px 20px; font-size: 15px; line-height: 1.6; color: var(--plum-600);">Trente minutes pour valider ensemble si un format correspond à votre situation.</p>
            <a href="https://app.lemcal.com/@nicolasdrouet/nicolas-drouet" class="btn-plum m-cta-block" style="display: inline-block; background: var(--plum-900); color: rgb(255, 255, 255); font-weight: 700; font-size: 15.5px; padding: 14px 26px; border-radius: 12px;">Choisir un créneau de 30 min</a>
          </div>
          <div class="card-lift m-card-pad" style="border: 1px solid var(--plum-200); border-radius: 14px; padding: 28px 32px; background: var(--plum-50); box-shadow: rgba(63, 4, 52, 0.08) 0px 2px 8px;">
            <div class="m-kicker" style="font-weight: 700; font-size: 12px; letter-spacing: 0.14em; color: var(--orange-700); margin-bottom: 16px;">CE QUI SE PASSE ENSUITE</div>
            <div style="display: flex; flex-direction: column; gap: 12px; font-size: 14.5px; line-height: 1.55; color: var(--plum-600);">
              <div style="display: flex; gap: 12px; align-items: baseline;"><span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-700); flex: 0 0 auto;">01</span><span>Nous lisons votre contexte et préparons le call.</span></div>
              <div style="display: flex; gap: 12px; align-items: baseline;"><span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-700); flex: 0 0 auto;">02</span><span>Trente minutes d'échange pour cadrer le besoin.</span></div>
              <div style="display: flex; gap: 12px; align-items: baseline;"><span style="font-family: var(--font-mono); font-size: 12px; color: var(--orange-700); flex: 0 0 auto;">03</span><span>Nous revenons avec le format ou la combinaison adaptée.</span></div>
            </div>
          </div>
          <div style="padding: 4px 8px;">
            <p class="m-body" style="margin: 0px; font-size: 13.5px; line-height: 1.6; color: var(--plum-500);">Vous préférez le mail ? <a href="mailto:nicolas@thegreencompagnon.com" style="font-weight: 700; color: var(--plum-900); border-bottom: 2px solid var(--orange-500); padding-bottom: 1px;">nicolas@thegreencompagnon.com</a></p>
          </div>
        </div>

      </div>
    </div>
    </main>

    <Footer variant="full" />
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const emailInput = document.getElementById('f-email') as HTMLInputElement;
    const telInput = document.getElementById('f-tel') as HTMLInputElement;
    const contexteInput = document.getElementById('f-contexte') as HTMLTextAreaElement;
    const emailError = document.querySelector('[data-error-for="f-email"]') as HTMLElement;
    const contexteError = document.querySelector('[data-error-for="f-contexte"]') as HTMLElement;
    const successMsg = document.getElementById('contact-success') as HTMLElement;
    const failureMsg = document.getElementById('contact-failure') as HTMLElement;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;

    const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function setFieldError(input: HTMLElement, errorEl: HTMLElement, message: string | null) {
      if (message) {
        errorEl.textContent = message;
        errorEl.style.display = 'block';
        input.style.borderColor = '#C0392B';
      } else {
        errorEl.textContent = '';
        errorEl.style.display = 'none';
        input.style.borderColor = 'var(--plum-200)';
      }
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      successMsg.style.display = 'none';
      failureMsg.style.display = 'none';

      let valid = true;

      if (!emailInput.value.trim()) {
        setFieldError(emailInput, emailError, 'Merci de renseigner votre email.');
        valid = false;
      } else if (!EMAIL_RE.test(emailInput.value.trim())) {
        setFieldError(emailInput, emailError, 'Cet email ne semble pas valide.');
        valid = false;
      } else {
        setFieldError(emailInput, emailError, null);
      }

      if (!contexteInput.value.trim()) {
        setFieldError(contexteInput, contexteError, 'Merci de décrire votre contexte.');
        valid = false;
      } else {
        setFieldError(contexteInput, contexteError, null);
      }

      if (!valid) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Envoi...';

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({
            access_key: '1476d813-26e1-41bd-9633-327c6b703cae',
            subject: 'Nouveau message — formulaire de contact AI Driven Academy',
            from_name: 'AI Driven Academy — Formulaire de contact',
            email: emailInput.value.trim(),
            tel: telInput.value.trim(),
            contexte: contexteInput.value.trim(),
          }),
        });

        const result = await response.json();

        if (result.success) {
          form.reset();
          successMsg.style.display = 'block';
        } else {
          failureMsg.style.display = 'block';
        }
      } catch {
        failureMsg.style.display = 'block';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Envoyer';
      }
    });
  </script>
</Layout>
