---
interface Props {
  heading: string;
  body: string;
  ctaLabel: string;
  ctaHref: string;
  note?: string;
  noteHref?: string;
}

const { heading, body, ctaLabel, ctaHref, note, noteHref } = Astro.props;
---
<div style="background: var(--orange-500); padding: 88px 64px; display: grid; grid-template-columns: 1fr auto; gap: 64px; align-items: center;">
  <div>
    <h2 style="font-family: var(--font-display); font-weight: 800; font-size: 48px; line-height: 1.08; letter-spacing: -0.02em; color: var(--plum-900); margin: 0px 0px 16px; text-wrap: balance;" set:html={heading} />
    <p style="margin: 0px; font-size: 16.5px; line-height: 1.6; color: rgba(63, 4, 52, 0.8); max-width: 640px;">{body}</p>
  </div>
  <div style="text-align: center;">
    <a href={ctaHref} class="btn-plum" style="display: inline-block; background: var(--plum-900); color: rgb(255, 255, 255); font-weight: 700; font-size: 17px; padding: 18px 36px; border-radius: 12px; white-space: nowrap;">{ctaLabel}</a>
    {note && noteHref && <div style="margin-top: 16px; font-family: var(--font-mono); font-size: 12.5px;"><a href={noteHref} style="color: rgba(63, 4, 52, 0.8);">{note}</a></div>}
    {note && !noteHref && <div style="margin-top: 16px; font-family: var(--font-mono); font-size: 12.5px; color: rgba(63, 4, 52, 0.8);">{note}</div>}
  </div>
</div>
