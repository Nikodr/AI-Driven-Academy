---
interface Item {
  label: string;
  href?: string;
  active?: boolean;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---
<div style="background: linear-gradient(transparent 50%, rgb(255, 255, 255) 50%); padding: 0px 64px;">
  <div style="display: flex; align-items: center; border: 1px solid rgba(255, 255, 255, 0.18); border-radius: 999px; padding: 16px 30px; background: var(--plum-800); box-shadow: rgba(26, 1, 22, 0.35) 0px 12px 32px; justify-content: space-between;">
    {items.map((item, i) => (
      <>
        {i > 0 && <span style="color: rgba(255, 255, 255, 0.4);">→</span>}
        {item.active ? (
          <span style="display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.1em; color: var(--plum-900); background: var(--orange-500); padding: 7px 16px; border-radius: 999px; font-weight: 700;">
            <span style="width: 7px; height: 7px; border-radius: 50%; background: var(--plum-900); animation: 1.8s ease-out 0s infinite normal none running ada-pulse;"></span>{item.label}
          </span>
        ) : item.href ? (
          <a href={item.href} style="font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.1em; color: rgb(255, 255, 255);">{item.label}</a>
        ) : (
          <span style="font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.1em; color: rgba(255, 255, 255, 0.68);">{item.label}</span>
        )}
      </>
    ))}
  </div>
</div>
