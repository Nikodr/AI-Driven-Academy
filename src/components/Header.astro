---
interface Props {
  active: 'accueil' | 'formations' | 'studio' | 'contact';
}

const { active } = Astro.props;
---
<header style="display: flex; align-items: center; gap: 32px; padding: 22px 64px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); position: sticky; top: 0px; background: rgba(26, 1, 22, 0.92); backdrop-filter: blur(8px); z-index: 50; color: rgb(255, 255, 255);">
  <a href="/" style="display: flex; align-items: center; gap: 12px; color: rgb(255, 255, 255);">
    <img src="/assets/icon-orange.png" alt="AI Driven Academy" width="34" height="34" style="width: 34px; height: 34px; border-radius: 9px; display: block;" />
    <span style="font-family: var(--font-display); font-weight: 700; font-size: 19px; letter-spacing: -0.01em;">AI Driven Academy</span>
  </a>
  <nav style="display: flex; gap: 28px; margin-left: auto; font-size: 15px; font-weight: 500; color: rgba(255, 255, 255, 0.78);">
    <a href="/" style={active === 'accueil' ? 'color: rgb(255, 255, 255); border-bottom: 2px solid var(--orange-500); padding-bottom: 2px;' : 'color: inherit;'}>Accueil</a>
    <a href="/offre" style={active === 'formations' ? 'color: rgb(255, 255, 255); border-bottom: 2px solid var(--orange-500); padding-bottom: 2px;' : 'color: inherit;'}>Nos formations</a>
  </nav>
  <a href="/studio" style={active === 'studio'
    ? 'font-size: 12.5px; color: rgb(255, 255, 255); border-left: 1px solid rgba(255, 255, 255, 0.15); padding-left: 28px;'
    : 'font-size: 12.5px; color: rgba(255, 255, 255, 0.55); border-left: 1px solid rgba(255, 255, 255, 0.15); padding-left: 28px;'}>
    {active === 'studio'
      ? <span style="border-bottom: 2px solid var(--orange-500); padding-bottom: 2px;">AI Academy Studio - Partners</span>
      : 'AI Academy Studio - Partners'}
  </a>
  <a href="/contact" class="btn-orange" style="background: var(--orange-500); color: rgb(255, 255, 255); font-weight: 600; font-size: 14.5px; padding: 12px 22px; border-radius: 10px;">Cadrer votre besoin</a>
</header>
