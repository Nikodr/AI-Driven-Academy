---
interface Props {
  active: 'accueil' | 'formations' | 'studio' | 'contact';
}

const { active } = Astro.props;
const casHref = active === 'accueil' ? '#cas' : '/#cas';
const equipeHref = active === 'accueil' ? '#equipe' : '/#equipe';
---
<header style="display: flex; align-items: center; gap: 32px; padding: 22px 64px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); position: sticky; top: 0px; background: rgba(26, 1, 22, 0.92); backdrop-filter: blur(8px); z-index: 50; color: rgb(255, 255, 255);">
  <a href="/" style="display: flex; align-items: center; gap: 12px; color: rgb(255, 255, 255);">
    <img src="/assets/icon-orange.png" alt="AI Driven Academy" width="34" height="34" style="width: 34px; height: 34px; border-radius: 9px; display: block;" />
    <span style="font-family: var(--font-display); font-weight: 700; font-size: 19px; letter-spacing: -0.01em;">AI Driven Academy</span>
  </a>
  <nav class="m-hide" style="display: flex; gap: 28px; margin-left: auto; font-size: 15px; font-weight: 500; color: rgba(255, 255, 255, 0.78);">
    <a href="/" style={active === 'accueil' ? 'color: rgb(255, 255, 255); border-bottom: 2px solid var(--orange-500); padding-bottom: 2px;' : 'color: inherit;'}>Accueil</a>
    <a href="/offre" style={active === 'formations' ? 'color: rgb(255, 255, 255); border-bottom: 2px solid var(--orange-500); padding-bottom: 2px;' : 'color: inherit;'}>Nos formations</a>
  </nav>
  <a href="/studio" class="m-hide" style={active === 'studio'
    ? 'font-size: 12.5px; color: rgb(255, 255, 255); border-left: 1px solid rgba(255, 255, 255, 0.15); padding-left: 28px;'
    : 'font-size: 12.5px; color: rgba(255, 255, 255, 0.55); border-left: 1px solid rgba(255, 255, 255, 0.15); padding-left: 28px;'}>
    {active === 'studio'
      ? <span style="border-bottom: 2px solid var(--orange-500); padding-bottom: 2px;">AI Academy Studio - Partners</span>
      : 'AI Academy Studio - Partners'}
  </a>
  <a href="/contact" class="btn-orange m-hide" style="background: var(--orange-500); color: rgb(255, 255, 255); font-weight: 600; font-size: 14.5px; padding: 12px 22px; border-radius: 10px;">Cadrer votre besoin</a>

  <button type="button" class="header-burger" id="menu-toggle" aria-label="Menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<div class="mobile-menu-overlay" id="mobile-menu">
  <div style="display: flex; align-items: center; gap: 10px;">
    <img src="/assets/icon-orange.png" alt="AI Driven Academy" width="32" height="32" style="width: 32px; height: 32px; border-radius: 9px; display: block;" />
    <span style="font-family: var(--font-display); font-weight: 700; font-size: 16.5px;">AI Driven Academy</span>
    <button type="button" class="menu-close" id="menu-close" aria-label="Fermer">×</button>
  </div>
  <nav>
    <a href="/" class:list={{ 'is-active': active === 'accueil' }}>Accueil{active === 'accueil' && <span style="color: var(--orange-500);"> ·</span>}</a>
    <a href="/offre" class:list={{ 'is-active': active === 'formations' }}>Nos formations{active === 'formations' && <span style="color: var(--orange-500);"> ·</span>}</a>
    <a href={casHref}>Études de cas</a>
    <a href={equipeHref}>À propos</a>
  </nav>
  <a href="/contact" class="menu-cta">Cadrer votre besoin</a>
  <a href="/studio" class:list={['menu-studio', { 'is-active': active === 'studio' }]}>AI Academy Studio - Partners</a>
</div>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById('menu-toggle');
    const close = document.getElementById('menu-close');
    const overlay = document.getElementById('mobile-menu');
    if (!toggle || !overlay) return;

    const open = () => {
      overlay.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('menu-open');
    };
    const closeMenu = () => {
      overlay.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('menu-open');
    };

    toggle.addEventListener('click', open);
    close?.addEventListener('click', closeMenu);
    overlay.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
  }

  initMobileMenu();
</script>
