---
interface Props {
  variant?: 'full' | 'minimal';
}

const { variant = 'full' } = Astro.props;
---
{variant === 'full' ? (
  <footer style="background: var(--plum-900); color: rgb(255, 255, 255); padding: 56px 64px 48px;">
    <div style="display: flex; align-items: flex-start; gap: 64px;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <img src="/assets/icon-orange.png" alt="AI Driven Academy" width="34" height="34" style="width: 34px; height: 34px; border-radius: 9px; display: block;" />
        <span style="font-family: var(--font-display); font-weight: 700; font-size: 18px; color: rgb(255, 255, 255);">AI Driven Academy</span>
      </div>
      <nav style="display: flex; gap: 26px; font-size: 14.5px; font-weight: 500;">
        <a href="/offre" style="color: rgba(255, 255, 255, 0.78);">Nos formations</a>
        <a href="#" style="color: rgba(255, 255, 255, 0.78);">Catalogue des modules</a>
        <a href="#" style="color: rgba(255, 255, 255, 0.78);">LinkedIn</a>
      </nav>
      <div style="margin-left: auto; text-align: right;">
        <a href="mailto:contact@aidrivenacademy.com" style="font-family: var(--font-mono); font-size: 13.5px; color: var(--orange-500);">contact@aidrivenacademy.com</a>
        <div style="margin-top: 10px; font-size: 12.5px; color: rgba(255, 255, 255, 0.55);"><a href="/studio" style="color: inherit;">AI Academy Studio, pour les ESN et cabinets</a></div>
      </div>
    </div>
    <div style="display: flex; gap: 24px; margin-top: 40px; padding-top: 22px; border-top: 1px solid rgba(255, 255, 255, 0.12); font-size: 12.5px; color: rgba(255, 255, 255, 0.55);">
      <span>© 2026 AI Driven Academy — SIRET [à compléter]</span>
      <a href="#" style="color: inherit;">Mentions légales</a>
      <a href="#" style="color: inherit;">CGV</a>
      <a href="#" style="color: inherit;">Politique de confidentialité</a>
    </div>
  </footer>
) : (
  <footer style="background: var(--plum-900); color: rgb(255, 255, 255); padding: 48px 64px 42px;">
    <div style="display: flex; align-items: center; gap: 32px;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <img src="/assets/icon-orange.png" alt="AI Driven Academy" width="30" height="30" style="width: 30px; height: 30px; border-radius: 8px; display: block;" />
        <span style="font-family: var(--font-display); font-weight: 700; font-size: 16px; color: rgb(255, 255, 255);">AI Academy Studio</span>
        <span style="font-weight: 600; font-size: 11.5px; letter-spacing: 0.14em; color: rgba(255, 255, 255, 0.55);">PAR AI DRIVEN ACADEMY</span>
      </div>
      <div style="margin-left: auto;">
        <a href="mailto:contact@aidrivenacademy.com" style="font-family: var(--font-mono); font-size: 13.5px; color: var(--orange-500);">contact@aidrivenacademy.com</a>
      </div>
    </div>
    <div style="display: flex; gap: 24px; margin-top: 32px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.12); font-size: 12.5px; color: rgba(255, 255, 255, 0.55);">
      <span>© 2026 AI Driven Academy — SIRET [à compléter]</span>
      <a href="#" style="color: inherit;">Mentions légales</a>
      <a href="#" style="color: inherit;">Politique de confidentialité</a>
    </div>
  </footer>
)}
