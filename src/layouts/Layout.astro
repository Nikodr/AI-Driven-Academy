---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path: string;
  noindex?: boolean;
  ogImage?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown>[];
}

const {
  title,
  description,
  path,
  noindex = false,
  ogImage = '/assets/og-image.png',
  ogType = 'website',
  structuredData = [],
} = Astro.props;

const SITE_URL = 'https://aidriven.academy';
const canonicalURL = new URL(path, SITE_URL).toString();
const ogImageURL = new URL(ogImage, SITE_URL).toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  '@id': `${SITE_URL}/#organization`,
  name: 'AI Driven Academy',
  url: SITE_URL,
  logo: `${SITE_URL}/assets/icon-orange.png`,
  image: ogImageURL,
  description:
    "Organisme de formation et conseil qui apporte aux équipes product & tech une méthode de développement assisté par IA (Spec-Driven Development), du Discovery à la Delivery.",
  email: 'nicolas@thegreencompagnon.com',
  areaServed: 'FR',
  knowsAbout: [
    'Spec-Driven Development',
    'Développement assisté par IA',
    'Formation IA pour équipes tech et produit',
    'Product management',
    'Ingénierie logicielle',
  ],
  founder: [
    {
      '@type': 'Person',
      name: 'Aurélien Binder-Meunier',
      jobTitle: 'Fondateur — CTO, Engineering',
    },
    {
      '@type': 'Person',
      name: 'Nicolas Drouet',
      jobTitle: 'Fondateur — CPO, Stratégie produit',
    },
  ],
};

const jsonLdBlocks = [organizationSchema, ...structuredData];
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1A0116" />

    <link rel="icon" type="image/png" href="/assets/icon-orange.png" />
    <link rel="apple-touch-icon" href="/assets/icon-orange.png" />
    <link rel="canonical" href={canonicalURL} />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="AI Driven Academy" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Fonts: preconnect + direct link (faster than @import in CSS) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,700;12..96,800&family=Figtree:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
